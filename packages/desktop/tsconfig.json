{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "composite": false,
        "outDir": "dist",
        "rootDir": "src",
        "module": "commonjs",
        "target": "ES2020",
        "lib": ["ES2020"],
        "types": ["node"],
        "skipLibCheck": true,
        "declaration": false,
        "noEmit": false
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules", "dist"]
}
